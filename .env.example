# Ragbot environment configuration template.
# Copy to .env and edit. Docker Compose reads .env automatically; for native
# CLI use, source it via `set -a; . .env; set +a` before running ragbot.

# --- Postgres / pgvector backend -----------------------------------------
# Used by docker-compose's `postgres` service AND the pgvector backend.
# Change the password before any non-local use.
POSTGRES_DB=ragbot
POSTGRES_USER=ragbot
POSTGRES_PASSWORD=ragbot_dev_password_change_me

# Connection string consumed by ragbot.
# Inside docker-compose the host is `postgres`; from the host machine use
# `localhost:5433` (the bound port from docker-compose.yml).
RAGBOT_DATABASE_URL=postgresql://ragbot:ragbot_dev_password_change_me@postgres:5432/ragbot
# RAGBOT_DATABASE_URL=postgresql://ragbot:ragbot_dev_password_change_me@localhost:5433/ragbot  # native CLI

# --- Demo mode (v3.2+) ---------------------------------------------------
# Set to 1 to use the bundled demo workspace + skill (in `demo/`) and
# hard-isolate discovery from any real workspaces on the host. The Web UI
# renders a banner; /health and /api/config report demo_mode: true.
# Equivalent to running `ragbot --demo`.
# RAGBOT_DEMO=1

# --- LLM backend selection (v3.1+) ---------------------------------------
# litellm (default; broad provider coverage) | direct (Anthropic + OpenAI +
# google-genai SDKs called directly, no third-party gateway).
RAGBOT_LLM_BACKEND=litellm

# --- Vector backend selection --------------------------------------------
# pgvector (default) | qdrant
RAGBOT_VECTOR_BACKEND=pgvector

# --- Qdrant fallback (when RAGBOT_VECTOR_BACKEND=qdrant) -----------------
# Embedded local-file mode is used when QDRANT_URL is unset.
# QDRANT_URL=http://qdrant:6333
QDRANT_PATH=/app/qdrant_data

# --- Discovery -----------------------------------------------------------
# Optional override. Unset by default; ragbot reads ~/.synthesis/console.yaml
# and ~/workspaces/*/ai-knowledge-* automatically.
# RAGBOT_BASE_PATH=/path/to/ai-knowledge

# Owner-context flag: set to 1 to expose -private repos in discovery.
# RAGBOT_OWNER_CONTEXT=1

# --- Embedding model ------------------------------------------------------
# Override the sentence-transformers model. Default: all-MiniLM-L6-v2 (384-dim).
# Changing this requires a full re-index (existing rows tag the model used).
# EMBEDDING_MODEL=all-MiniLM-L6-v2
